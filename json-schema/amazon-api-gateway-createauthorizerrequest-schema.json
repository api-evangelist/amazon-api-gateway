{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreateAuthorizerRequest",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the authorizer."
    },
    "type": {
      "type": "string",
      "enum": [
        "TOKEN",
        "REQUEST",
        "COGNITO_USER_POOLS"
      ]
    },
    "providerARNs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authType": {
      "type": "string"
    },
    "authorizerUri": {
      "type": "string"
    },
    "authorizerCredentials": {
      "type": "string"
    },
    "identitySource": {
      "type": "string"
    },
    "identityValidationExpression": {
      "type": "string"
    },
    "authorizerResultTtlInSeconds": {
      "type": "integer"
    }
  },
  "required": [
    "name",
    "type"
  ]
}