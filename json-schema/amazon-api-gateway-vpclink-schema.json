{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VpcLink",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "targetArns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "AVAILABLE",
        "PENDING",
        "DELETING",
        "FAILED"
      ]
    },
    "statusMessage": {
      "type": "string"
    },
    "tags": {
      "type": "object"
    }
  }
}